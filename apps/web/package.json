{
  "name": "scbkr-local-responsibility-web",
  "version": "2.3.0",
  "description": "SCBKR chat-first web UI with responsibility-chain rule drafts",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5500",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 5500",
    "test:ui": "playwright test",
    "test:ui:desktop": "playwright test --project=desktop-chromium",
    "test:ui:mobile": "playwright test --project=mobile-chromium",
    "test:ui:report": "playwright show-report"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.19",
    "@radix-ui/react-popover": "^1.1.19",
    "@radix-ui/react-switch": "^1.3.3",
    "@radix-ui/react-tabs": "^1.1.17",
    "@radix-ui/react-tooltip": "^1.2.12",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@vitejs/plugin-react": "latest",
    "clsx": "^2.1.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.22.0",
    "qrcode.react": "^4.2.0",
    "react": "latest",
    "react-dom": "latest",
    "three": "^0.185.0",
    "typescript": "latest",
    "vite": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/pngjs": "^6.0.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "pngjs": "^7.0.0"
  }

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scbkr.local/schemas/review_failed_rule.schema.json",
  "title": "review_failed_rule",
  "description": "SCBKR P11 review-failed memory rule draft and confirmed-plan schema. This schema describes planning records only and does not imply any memory write.",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "rule_id": { "type": "string" },
    "source_task_id": { "type": ["string", "null"] },
    "source_trace_id": { "type": ["string", "null"] },
    "source_ledger_id": { "type": ["string", "null"] },
    "source_review_status": { "type": "string" },
    "failure_summary": { "type": "string" },
    "failure_report_draft": { "type": "object" },
    "user_failure_judgement": { "type": "string" },
    "rule_statement": { "type": "string" },
    "applies_to_task_types": { "type": "array" },
    "trigger_conditions": { "type": "array" },
    "forbidden_patterns": { "type": "array" },
    "required_behavior": { "type": "array" },
    "reviewer_signature": { "type": ["string", "null"] },
    "memory_rule_status": { "type": "string", "enum": ["draft", "confirmed_plan"] },
    "requires_user_signature": { "type": "boolean", "default": true },
    "physical_write_performed": { "type": "boolean", "default": false },
    "next_required_action": { "type": "string" }
  },
  "required": [
    "rule_id",
    "source_task_id",
    "source_trace_id",
    "source_ledger_id",
    "source_review_status",
    "failure_summary",
    "failure_report_draft",
    "user_failure_judgement",
    "rule_statement",
    "applies_to_task_types",
    "trigger_conditions",
    "forbidden_patterns",
    "required_behavior",
    "reviewer_signature",
    "memory_rule_status",
    "requires_user_signature",
    "physical_write_performed",
    "next_required_action"
  ]
}

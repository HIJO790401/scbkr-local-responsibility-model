{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scbkr.local/schemas/rulepack.schema.json",
  "title": "SCBKR 2.0 RulePack",
  "type": "object",
  "additionalProperties": true,
  "required": ["pack_id", "name", "author", "version", "signature_algorithm", "public_key", "signature", "rules"],
  "properties": {
    "pack_id": {"type": "string"},
    "name": {"type": "string"},
    "author": {"type": "string"},
    "version": {"type": "string"},
    "signature_algorithm": {"const": "ed25519"},
    "public_key": {"type": ["string", "null"]},
    "signature": {"type": ["string", "null"]},
    "rules": {"type": "array", "items": {"type": "object"}}
  }
}

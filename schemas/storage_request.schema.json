{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://scbkr.local/schemas/storage_request.schema.json",
  "title": "SCBKR Storage Request",
  "description": "SCBKR P8 storage request schema. This represents a storage planning and second-confirmation structure only; it does not perform physical storage writes.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "task_id",
    "trace_id",
    "ledger_id",
    "review_status",
    "review_passed",
    "storage_confirmed",
    "candidate_targets",
    "selected_targets",
    "blocked_targets",
    "storage_signature",
    "storage_notes",
    "next_required_action"
  ],
  "properties": {
    "task_id": { "type": ["string", "null"] },
    "trace_id": { "type": ["string", "null"] },
    "ledger_id": { "type": ["string", "null"] },
    "review_status": { "type": "string" },
    "review_passed": { "type": "boolean" },
    "storage_confirmed": { "type": "boolean", "default": false },
    "candidate_targets": {
      "type": "array",
      "items": { "type": "string", "enum": ["vector", "corpus", "logic", "memory"] },
      "default": []
    },
    "selected_targets": {
      "type": "array",
      "items": { "type": "string", "enum": ["vector", "corpus", "logic", "memory"] },
      "default": []
    },
    "blocked_targets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["target", "reason"],
        "properties": {
          "target": { "type": "string" },
          "reason": { "type": "string" }
        }
      },
      "default": []
    },
    "storage_signature": { "type": ["string", "null"], "default": null },
    "storage_notes": { "type": "string", "default": "" },
    "next_required_action": { "type": "string" }
  }
}
